            "target": "vocals",
            "steps": [
                {
                    "model_id": "bs-roformer-viperx-1297",
                    "weight": 1.0
                }
            ],
            "post_processing": "high_pass",
            "post_processing_params": {
                "cutoff_hz": 500
            },
            "defaults": {
                "overlap": 4
            }
        },
        {
            "id": "workflow_phase_fix_instrumental",
            "name": "Phase Fix Instrumental (Workflow)",
            "description": "Separate with Unwa Inst v1e+, then phase-fix instrumental using Becruily Vocal as a phase reference (500-5000Hz).",
            "type": "pipeline",
            "target": "instrumental",
            "steps": [
                {
                    "action": "separate",
                    "model_id": "unwa-inst-v1e-plus",
                    "weight": 1.0
                },
                {
                    "action": "phase_fix",
                    "source_model": "becruily-vocal",
                    "lowHz": 500,
                    "highHz": 5000,
                    "weight": 2.0,
                    "apply_to": "instrumental"
                }
            ],
            "source": "In-app preset workflow",
            "vram_category": "high",
            "defaults": {
                "overlap": 4
            }
        }
