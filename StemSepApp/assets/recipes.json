      "id": "workflow_phase_fix_instrumental",
      "name": "Best Instrumental",
      "description": "Guide-first instrumental workflow: fullness from Unwa V1e+ with Becruily phase-fix cleanup.",
      "type": "pipeline",
      "target": "instrumental",
      "quality_goal": "premium_quality",
      "difficulty": "simple",
      "expected_vram_tier": "mid_vram",
      "expected_runtime_tier": "standard",
      "guide_rank": 1,
      "simple_surface": true,
      "simple_goal": "instrumental",
      "recommended_for": [
        "Highest quality instrumental extraction",
        "Songs where fullness matters more than raw speed"
      ],
      "contraindications": [
        "Very low VRAM systems",
        "Fast preview workflows"
      ],
      "workflow_summary": "Separate with Unwa V1e+, then phase-fix instrumental using Becruily Vocal at 500-5000 Hz.",
      "source": "Guide-derived simple workflow",
      "defaults": {
        "overlap": 4,
        "segment_size": 352800
      },
      "steps": [
        {
          "action": "separate",
          "model_id": "unwa-inst-v1e-plus",
          "weight": 1.0
        },
        {
          "action": "phase_fix",
          "source_model": "becruily-vocal",
          "lowHz": 500,
          "highHz": 5000,
          "weight": 2.0,
          "apply_to": "instrumental"
        }
      ]
    },
