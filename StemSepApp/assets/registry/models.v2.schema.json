{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stemsep.dev/schemas/models.v2.schema.json",
  "title": "StemSep Model Registry v2",
  "description": "Schema for StemSep's v2 model registry. This format is designed for deterministic runtime routing, explicit compatibility/requirements, and long-term maintainability. Guide recommendations are treated as MUST (strict-spec).",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "models"],
  "properties": {
    "version": {
      "type": "string",
      "const": "2.0"
    },
    "generated_at": {
      "type": "string",
      "description": "RFC 3339 timestamp of registry generation.",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "description": "Optional metadata about how this registry was produced.",
      "additionalProperties": false,
      "properties": {
        "tool": { "type": "string" },
        "repo": { "type": "string" },
        "commit": { "type": ["string", "null"] },
        "notes": { "type": "string" }
      }
    },
    "guide_revision": {
      "description": "Optional reference to the guide revision this registry sync is based on (e.g. date or doc revision marker).",
      "type": ["string", "null"]
    },
    "models": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/model" }
    }
  },
  "$defs": {
    "modelId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$",
      "description": "Canonical model identifier used throughout the app. Lowercase recommended; avoid spaces."
    },
    "url": {
      "type": "string",
      "minLength": 1,
      "format": "uri"
    },
    "numberOrNull": {
      "anyOf": [{ "type": "number" }, { "type": "null" }]
    },
    "boolOrNull": {
      "anyOf": [{ "type": "boolean" }, { "type": "null" }]
    },
    "stringOrNull": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },
    "stemName": {
      "type": "string",
      "description": "Canonical stem names used internally by StemSep.",
      "enum": [
        "vocals",
        "instrumental",
        "drums",
        "bass",
        "other",
        "guitar",
        "piano",
        "keys",
        "lead",
        "back",
        "crowd",
        "speech",
        "sfx",
        "effects",
        "music",
        "restored",
        "target",
        "residual"
      ]
    },
    "architecture": {
      "type": "string",
      "description": "Model architecture family.",
      "enum": [
        "BS-Roformer",
        "Mel-Roformer",
        "MDX23C",
        "MDX-Net",
        "VR",
        "Demucs",
        "HTDemucs",
        "SCNet",
        "Apollo",
        "BandIt",
        "Other"
      ]
    },
    "runtimeId": {
      "type": "string",
      "description": "Execution runtime identifier used for routing and enforcement.",
      "enum": ["audio-separator", "stemsep-legacy", "msst"]
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "architecture", "links", "runtime"],
      "properties": {
        "id": { "$ref": "#/$defs/modelId" },
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "description": "Human-facing category/type label (legacy field kept for compatibility)."
        },
        "architecture": { "$ref": "#/$defs/architecture" },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "description": "Optional tags for UI filtering (e.g. 'karaoke', 'dereverb', 'denoise', 'drumsep').",
          "items": { "type": "string", "minLength": 1 }
        },
        "stems": {
          "type": "array",
          "description": "Declared output stems (if known).",
          "items": { "$ref": "#/$defs/stemName" }
        },
        "links": { "$ref": "#/$defs/links" },
        "homepage": {
          "description": "Legacy informational URL retained for compatibility; prefer links.homepage.",
          "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }]
        },
        "artifacts": { "$ref": "#/$defs/artifacts" },
        "metrics": { "$ref": "#/$defs/metrics" },
        "sdr": {
          "description": "Legacy top-level metric retained for compatibility with older tooling.",
          "$ref": "#/$defs/numberOrNull"
        },
        "fullness": {
          "description": "Legacy top-level metric retained for compatibility with older tooling.",
          "$ref": "#/$defs/numberOrNull"
        },
        "bleedless": {
          "description": "Legacy top-level metric retained for compatibility with older tooling.",
          "$ref": "#/$defs/numberOrNull"
        },
        "card_metrics": { "$ref": "#/$defs/cardMetrics" },
        "catalog_status": {
          "type": "string",
          "enum": ["verified", "candidate", "blocked", "manual_only", "online_only"]
        },
        "metrics_status": {
          "type": "string",
          "enum": ["verified", "guide_curated", "vendor_matched", "missing_evidence"]
        },
        "metrics_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/metricsEvidence" }
        },
        "guide_rank": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "guide_notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "vram_required": {
          "description": "Approximate VRAM required in GB (rough guidance).",
          "$ref": "#/$defs/numberOrNull"
        },
        "recommended_settings": { "$ref": "#/$defs/recommendedSettings" },
        "settings_semantics": { "$ref": "#/$defs/settingsSemantics" },
        "runtime": { "$ref": "#/$defs/runtime" },
        "install": {
          "description": "Legacy install metadata retained for compatibility while download manifests are normalized.",
          "type": "object",
          "additionalProperties": true
        },
        "status": { "$ref": "#/$defs/status" },
        "compatibility": { "$ref": "#/$defs/compatibility" },
        "requirements": { "$ref": "#/$defs/requirements" },
        "phase_fix": { "$ref": "#/$defs/phaseFix" },
        "capabilities": { "$ref": "#/$defs/capabilities" },
        "notes": { "$ref": "#/$defs/notes" }
        ,
        "guide_revision": {
          "description": "Guide revision marker for this model row (e.g. '2026-03-04').",
          "type": ["string", "null"]
        },
        "quality_profile": {
          "type": "object",
          "additionalProperties": false,
          "description": "Quality-driven profile metadata used by policy selection and A/B comparisons.",
          "properties": {
            "target_roles": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["vocals", "instrumental", "karaoke", "restoration", "multi_stem", "bass", "drums"]
              }
            },
            "quality_tier": {
              "type": ["string", "null"],
              "enum": ["fast", "balanced", "quality", "ultra", null]
            },
            "deterministic_priority": {
              "type": ["integer", "null"],
              "minimum": 1
            }
          }
        },
        "hardware_tiers": {
          "type": "array",
          "description": "Hardware suitability hints for policy routing.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "tier": {
                "type": "string",
                "enum": ["low_vram", "mid_vram", "high_vram", "cpu_only"]
              },
              "min_vram_gb": { "$ref": "#/$defs/numberOrNull" },
              "max_vram_gb": { "$ref": "#/$defs/numberOrNull" },
              "recommended_segment_size": {
                "type": ["integer", "null"],
                "minimum": 1
              },
              "recommended_overlap": { "type": ["integer", "null"] },
              "notes": { "type": "string" }
            }
          }
        },
        "stability_notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "quality_role": {
          "anyOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          ]
        },
        "best_for": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "artifacts_risk": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "vram_profile": { "type": ["string", "null"] },
        "chunk_overlap_policy": {
          "type": "object",
          "additionalProperties": true
        },
        "workflow_groups": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "quality_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "workflow_roles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "operating_profiles": {
          "type": "object",
          "additionalProperties": true
        },
        "content_fit": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "download": {
          "$ref": "#/$defs/download"
        },
        "availability": {
          "$ref": "#/$defs/availability"
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "checkpoint": {
          "description": "Primary weights/checkpoint URL.",
          "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }]
        },
        "config": {
          "description": "Optional config URL (yaml/json).",
          "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }]
        },
        "homepage": {
          "description": "Optional informational link (HF card, MVSEP entry, etc.).",
          "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }]
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "description": "Standardized local artifact expectations. If present, generators should prefer these over deriving basenames from URLs.",
      "properties": {
        "primary": { "$ref": "#/$defs/artifactRef" },
        "config": {
          "anyOf": [{ "$ref": "#/$defs/artifactRef" }, { "type": "null" }]
        },
        "additional": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactRef" }
        }
      }
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "filename"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["checkpoint", "config", "onnx", "yaml", "json", "aux"]
        },
        "filename": {
          "type": "string",
          "minLength": 1,
          "description": "Filename expected under the models directory."
        },
        "sha256": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
            { "type": "null" }
          ],
          "description": "Optional SHA-256 for integrity validation."
        },
        "size_bytes": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "availability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class"],
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "direct",
            "mirror_fallback",
            "manual_import",
            "blocked_non_public"
          ]
        },
        "reason": {
          "type": ["string", "null"]
        }
      }
    },
    "downloadSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": { "$ref": "#/$defs/url" },
        "role": { "type": "string" },
        "channel": {
          "type": "string",
          "enum": ["upstream", "mirror"]
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "auth": {
          "type": "string",
          "enum": ["none", "hf_token"]
        },
        "verified": { "type": "boolean" },
        "host": { "type": "string" },
        "manual": { "type": "boolean" }
      }
    },
    "downloadArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "filename", "relative_path"],
      "properties": {
        "kind": { "type": "string" },
        "filename": { "type": "string", "minLength": 1 },
        "relative_path": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "manual": { "type": "boolean" },
        "source": {
          "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }]
        },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/downloadSource" }
        },
        "sha256": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
            { "type": "null" }
          ]
        },
        "size_bytes": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "channel": { "type": "string" },
        "auth": { "type": "string" },
        "verified": { "type": "boolean" }
      }
    },
    "download": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "direct",
            "mirror_fallback",
            "manual_import",
            "blocked_non_public"
          ]
        },
        "mode": { "type": "string" },
        "install_mode": { "type": "string" },
        "family": { "type": "string" },
        "artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "downloadable_artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "manual_instructions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/downloadSource" }
        },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/downloadArtifact" }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sdr": { "$ref": "#/$defs/numberOrNull" },
        "fullness": { "$ref": "#/$defs/numberOrNull" },
        "bleedless": { "$ref": "#/$defs/numberOrNull" },
        "aura_stft": { "$ref": "#/$defs/numberOrNull" },
        "aura_mrstft": { "$ref": "#/$defs/numberOrNull" },
        "log_wmse": { "$ref": "#/$defs/numberOrNull" }
      }
    },
    "cardMetricValue": {
      "anyOf": [{ "type": "number" }, { "type": "string" }, { "type": "null" }]
    },
    "cardMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "primary_target",
        "labels",
        "values",
        "source",
        "last_verified"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["standard", "special", "status"]
        },
        "primary_target": {
          "type": "string",
          "minLength": 1
        },
        "labels": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "values": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/cardMetricValue" }
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "evidence_url": {
          "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }]
        },
        "evidence_note": {
          "type": ["string", "null"]
        },
        "last_verified": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "metricsEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "note", "verified_at"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "anyOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }]
        },
        "note": {
          "type": "string",
          "minLength": 1
        },
        "verified_at": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "recommendedSettings": {
      "type": "object",
      "additionalProperties": false,
      "description": "Recommended settings. Semantics MUST be interpreted using settings_semantics.",
      "properties": {
        "segment_size": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Chunk/segment size in samples (when applicable)."
        },
        "batch_size": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Batch size (when applicable)."
        },
        "tta": { "$ref": "#/$defs/boolOrNull" },
        "overlap": { "type": ["integer", "null"] },
        "shifts": { "type": ["integer", "null"] },
        "bit_depth": { "anyOf": [{ "type": "integer" }, { "type": "null" }] }
      }
    },
    "settingsSemantics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "overlap": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "meaning_by_runtime": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "audio-separator": { "type": "string" },
                "stemsep-legacy": { "type": "string" },
                "msst": { "type": "string" }
              }
            },
            "notes": { "type": "string" }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "preferred"],
      "properties": {
        "allowed": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeId" }
        },
        "preferred": { "$ref": "#/$defs/runtimeId" },
        "blocking_reason": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "variant": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "engine": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "model_type": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "install_mode": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "hosts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "install_burden": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "required": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fallbacks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "required_files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "requires_manual_assets": { "$ref": "#/$defs/boolOrNull" },
        "requires_patch": { "$ref": "#/$defs/boolOrNull" },
        "requires_custom_repo_file": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "checkpoint_ref": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "config_ref": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "patch_profile": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "readiness": {
          "type": ["string", "null"],
          "enum": ["verified", "experimental", "manual", "blocked", null]
        },
        "simple_allowed": { "$ref": "#/$defs/boolOrNull" },
        "blocking_reason": { "$ref": "#/$defs/stringOrNull" },
        "curated": { "$ref": "#/$defs/boolOrNull" },
        "support_tier": {
          "type": ["string", "null"],
          "enum": ["curated", "supported_advanced", null]
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "uvr_compatible": { "$ref": "#/$defs/boolOrNull" },
        "audio_separator_compatible": { "$ref": "#/$defs/boolOrNull" },
        "msst_compatible": { "$ref": "#/$defs/boolOrNull" },
        "known_issues": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "python": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": { "type": ["string", "null"] },
            "max": { "type": ["string", "null"] }
          }
        },
        "torch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": { "type": ["string", "null"] },
            "max": { "type": ["string", "null"] },
            "cuda": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "rocm": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "pip": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "packages": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "files": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "expects": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "provides": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "manual_steps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "phaseFix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "is_valid_reference": { "$ref": "#/$defs/boolOrNull" },
        "recommended_params": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "lowHz": { "$ref": "#/$defs/numberOrNull" },
            "highHz": { "$ref": "#/$defs/numberOrNull" },
            "highFreqWeight": { "$ref": "#/$defs/numberOrNull" }
          }
        },
        "recommended_usage": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reference_model_id": {
          "anyOf": [{ "$ref": "#/$defs/modelId" }, { "type": "null" }]
        },
        "references": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/modelId" }
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stems": {
          "type": "array",
          "items": { "$ref": "#/$defs/stemName" }
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "separation",
              "phase_fix_reference",
              "karaoke",
              "denoise",
              "dereverb",
              "decrowd",
              "drumsep",
              "upsample",
              "sfx",
              "speech",
              "restoration"
            ]
          }
        },
        "supports_mono": { "$ref": "#/$defs/boolOrNull" },
